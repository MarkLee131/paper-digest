# MkDocs build output
site/

# Legacy Jekyll output (in case anything still emits it)
_site/
.jekyll-cache/
.jekyll-metadata
.sass-cache/

# OS
.DS_Store
Thumbs.db

# Editors
.vscode/
.idea/
*.swp
*~

# Python
__pycache__/
*.pyc
.venv/

# Local task scratch
.scratch/
*.tmp
*.log

# Private archive — full uncensored reports including Bypass/Remove evaluations
# and any other content we deliberately keep out of the public Pages site.
.private/

# Sandbox FUSE-mount leftovers — git filter-branch / lock-file backups that the
# sandbox cannot unlink. Safe to ignore; cleaned up on next host-side `git gc`.
.git-rewrite/
.git-rewrite.bak.*/

# Pandoc intermediate HTML staged inside the daily report dirs because the
# sandbox FUSE mount cannot delete files. Safe to ignore; the .pdf is the
# real deliverable.
docs/reports/*/_pub.html
docs/reports/*/_pub.html.bak.*
docs/reports/*/_priv.html

